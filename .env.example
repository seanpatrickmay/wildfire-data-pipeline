# Wildfire Data Pipeline — Environment Variables
# Copy this to .env and fill in your values

# Google Earth Engine project ID (required for asset exports)
# Find yours at: https://console.cloud.google.com/
WILDFIRE_GEE_PROJECT=your-gcp-project-id

# Use high-volume GEE endpoint (recommended, default: true)
WILDFIRE_GEE_HIGHVOLUME=true

# Logging level (DEBUG, INFO, WARNING, ERROR)
WILDFIRE_LOG_LEVEL=INFO

# Default output directory
WILDFIRE_OUTPUT_DIR=data
